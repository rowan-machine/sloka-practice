# Required for TTS (Text-to-Speech) pronunciation features
# Get your key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Choose a specific ElevenLabs voice ID
# Default: XB0fDUnXU5powFXDhCwa (Charlotte)
ELEVENLABS_VOICE_ID=

# For deployed frontend: set this to your backend URL
# e.g. https://sloka-tts-server.onrender.com
# Leave empty for local development (uses proxy or localhost:3001)
VITE_API_URL=
